#build artifacts
/build/
/CMakeFiles/
/CMakeCache.txt
cmake_install.cmake
Makefile

#object files and binaries
*.o
*.obj
*.exe
*.out
*.app

#coverage, logs, etc
*.log
*.tmp

#IDE and editor settings
.vscode/
*.sublime-project
*.sublime-workspace
*.idea/
*.swp

#OS generated files
.DS_Store
Thumbs.db

#generated by GLAD
glad.c

#ignore any library outputs
*.lib
*.a
*.dll
*.so

#ignore user-specific files
*.user
*.pro.user

#ignore build directories or temporary files
**/CMakeFiles/*
**/cmake_install.cmake
**/Makefile

#ignore any generated shaders or caching
*.spv

#ignore compiled Python files if present
*.pyc
__pycache__/